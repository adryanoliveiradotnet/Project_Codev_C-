<hc:Window
        x:Class="Codev_V2.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:local="clr-namespace:Codev_V2"
        xmlns:hc="https://handyorg.github.io/handycontrol" 
        Title="LoginWindow" Height="450" Width="400"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        BorderBrush="Transparent"
        WindowStartupLocation="CenterScreen"
        Opacity="10"
        ResizeMode="NoResize" Loaded="Window_Loaded">
    <hc:Window.Resources>
        <Style TargetType="Control">
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>
    </hc:Window.Resources>
    <Border Background="#FF222325" CornerRadius="10" BorderThickness="1" BorderBrush="#FF393A3A">
        <Grid x:Name="Login" RenderTransformOrigin="0.621,0.821">
            <hc:TextBox Name="User_" hc:InfoElement.Placeholder="Usuário" HorizontalAlignment="Center" Margin="0,192,0,0" VerticalAlignment="Top" Width="236" Height="30" Background="#393C44" BorderThickness="0,0,0,0" Foreground="#E0E1E6" FontWeight="SemiBold" CaretBrush="{x:Null}"/>
            <hc:PasswordBox Name="Pass_" hc:InfoElement.Placeholder="Senha" HorizontalAlignment="Center" Margin="0,236,0,0" VerticalAlignment="Top" Width="236" Height="30" Background="#393C44" BorderThickness="0,0,0,0" Foreground="#E0E1E6" FontWeight="SemiBold"/>
            <Button Content="Login" Margin="81,304,81,0" VerticalAlignment="Top" Width="236" Height="30" Background="#2A7AFF"  BorderThickness="1" Foreground="#E0E1E6" FontWeight="SemiBold" Click="Button_Click" BorderBrush="#2A7AFF"/>
            <Button x:Name="Fechar" Content="✖" Margin="345,3,0,0" VerticalAlignment="Top" Background="Transparent"   BorderThickness="0,0,0,0" Foreground="#6B6C6F" RenderTransformOrigin="-0.485,1.585" Click="Fechar_Click" Width="50" HorizontalAlignment="Left" Height="50"/>
            <Image HorizontalAlignment="Left" Height="100" Margin="152,56,0,0" VerticalAlignment="Top" Width="100" Source="/logo_dashbord.png" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
            <ToggleButton x:Name="SalvarLogin" Content="Lembrar Senha?" HorizontalContentAlignment="Right" Margin="81,273,81,151" Foreground="#E0E1E6" FontWeight="SemiBold" Background="#393C44" Height="20" Cursor="" Checked="ToggleButton_Checked" Unchecked="ToggleButton_Unchecked">
                <ToggleButton.Resources>
                    <SolidColorBrush x:Key="PrimaryBrush" Color="#2A7AFF"/>
                </ToggleButton.Resources>
                <ToggleButton.Style>
                    <StaticResource ResourceKey="ToggleButtonSwitch"/>
                </ToggleButton.Style>
            </ToggleButton>
            <TextBlock HorizontalAlignment="Left" Margin="81,339,0,0" TextWrapping="Wrap" Text="Não tem uma conta?" VerticalAlignment="Top" FontWeight="SemiBold" Foreground="#E0E1E6"/>
            <TextBlock HorizontalAlignment="Left" Margin="253,339,0,0" TextWrapping="Wrap" Text="Cadastre-se" VerticalAlignment="Top" FontWeight="SemiBold" Foreground="#E0E1E6"/>
        </Grid>
    </Border>
</hc:Window>