<hc:Window x:Class="Codev_V2.Splash"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:hc="https://handyorg.github.io/handycontrol" 
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Codev_V2"
        mc:Ignorable="d"
        Title="Init" Height="250" Width="500"
        AllowsTransparency="True"
        WindowStyle="None"
        Background="Transparent"
        BorderBrush="Transparent"
        WindowStartupLocation="CenterScreen"
        Opacity="10"
        ResizeMode="NoResize" Loaded="Window_Loaded">
    <Border Background="#212328" CornerRadius="10" BorderThickness="1" BorderBrush="#FF393A3A">
        <Grid>
            <Label HorizontalAlignment="Center" Content="Carregando..." Margin="0,216,0,0" VerticalAlignment="Top" Background="Transparent" FontFamily="Segoe UI Semibold" BorderBrush="Transparent" Foreground="#E0E1E6" FontWeight="Bold"/>
            <Image HorizontalAlignment="Center" Height="100" VerticalAlignment="Center" Width="100" Source="/logo_dashbord.png" RenderOptions.BitmapScalingMode="HighQuality" SnapsToDevicePixels="True" UseLayoutRounding="True"/>
        </Grid>
    </Border>
</hc:Window>